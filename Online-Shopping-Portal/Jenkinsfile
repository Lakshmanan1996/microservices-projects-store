pipeline {

    agent none

    environment {
        DOCKERHUB_USER = "lakshvar96"

        IMAGE1 = "adminserver"
        IMAGE2 = "product"
        IMAGE3 = "userservice"

        GIT_REPO = "https://github.com/Lakshmanan1996/microservices-projects-store.git"
    }

    options {
        timestamps()
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    stages {

        /* =========================================================
           CHECKOUT
        ========================================================= */
        stage('Checkout') {

            agent { label 'workernode1' }

            steps {

                git branch: 'master',
                url: "${GIT_REPO}"

                sh """
                echo "Repository cloned successfully"
                pwd
                ls -R
                """
            }
        }

        /* =========================================================
           BUILD SERVICES
        ========================================================= */
        stage('Build Services') {

            agent { label 'workernode1' }

            steps {

                sh """
                echo "========== BUILDING ADMINSERVER =========="

                cd Online-Shopping-Portal/adminserver

                chmod +x gradlew

                ./gradlew clean build -x test

                echo "========== BUILDING PRODUCT =========="

                cd ../product

                chmod +x gradlew

                ./gradlew clean build -x test

                echo "========== BUILDING USERSERVICE =========="

                cd ../userservice

                chmod +x gradlew

                ./gradlew clean build -x test
                """
            }
        }

        /* =========================================================
           SONARQUBE ANALYSIS
        ========================================================= */
        stage('SonarQube Analysis') {

            agent { label 'workernode2' }

            steps {

                /*
                 Because workernode2 has different workspace,
                 checkout code again
                */

                git branch: 'master',
                url: "${GIT_REPO}"

                withSonarQubeEnv('sonarqube') {

                    sh """
                    echo "========== SONAR SCAN : ADMINSERVER =========="

                    cd Online-Shopping-Portal/adminserver

                    chmod +x gradlew

                    ./gradlew sonarqube \
                    -Dsonar.projectKey=adminserver \
                    -Dsonar.projectName=adminserver

                    echo "========== SONAR SCAN : PRODUCT =========="

                    cd ../product

                    chmod +x gradlew

                    ./gradlew sonarqube \
                    -Dsonar.projectKey=product \
                    -Dsonar.projectName=product

                    echo "========== SONAR SCAN : USERSERVICE =========="

                    cd ../userservice

                    chmod +x gradlew

                    ./gradlew sonarqube \
                    -Dsonar.projectKey=userservice \
                    -Dsonar.projectName=userservice
                    """
                }
            }
        }

        /* =========================================================
           QUALITY GATE
        ========================================================= */
        stage('Quality Gate') {

            agent { label 'workernode2' }

            steps {

                timeout(time: 5, unit: 'MINUTES') {

                    waitForQualityGate abortPipeline: true
                }
            }
        }

        /* =========================================================
           OWASP DEPENDENCY CHECK
        ========================================================= */
        stage('OWASP Dependency Check') {

            agent { label 'workernode2' }

            steps {

                dependencyCheck(
                    additionalArguments: '''
                        --scan .
                        --format HTML
                        --format XML
                        --out reports
                    ''',
                    odcInstallation: 'OWASP-DC'
                )

                dependencyCheckPublisher(
                    pattern: '**/dependency-check-report.xml'
                )
            }
        }

        /* =========================================================
           DOCKER BUILD
        ========================================================= */
        stage('Docker Build') {

            agent { label 'workernode3' }

            steps {

                /*
                 Different node again,
                 checkout repository again
                */

                git branch: 'master',
                url: "${GIT_REPO}"

                sh """
                echo "========== BUILDING DOCKER IMAGES =========="

                docker build -t ${DOCKERHUB_USER}/${IMAGE1}:${BUILD_NUMBER} \
                Online-Shopping-Portal/adminserver

                docker build -t ${DOCKERHUB_USER}/${IMAGE2}:${BUILD_NUMBER} \
                Online-Shopping-Portal/product

                docker build -t ${DOCKERHUB_USER}/${IMAGE3}:${BUILD_NUMBER} \
                Online-Shopping-Portal/userservice

                echo "========== TAGGING IMAGES =========="

                docker tag ${DOCKERHUB_USER}/${IMAGE1}:${BUILD_NUMBER} \
                ${DOCKERHUB_USER}/${IMAGE1}:latest

                docker tag ${DOCKERHUB_USER}/${IMAGE2}:${BUILD_NUMBER} \
                ${DOCKERHUB_USER}/${IMAGE2}:latest

                docker tag ${DOCKERHUB_USER}/${IMAGE3}:${BUILD_NUMBER} \
                ${DOCKERHUB_USER}/${IMAGE3}:latest
                """
            }
        }

        /* =========================================================
           TRIVY SCAN
        ========================================================= */
        stage('Trivy Scan') {

            agent { label 'workernode3' }

            steps {

                sh """
                echo "========== TRIVY SCAN : ADMINSERVER =========="

                trivy image --severity HIGH,CRITICAL --exit-code 0 \
                ${DOCKERHUB_USER}/${IMAGE1}:${BUILD_NUMBER}

                echo "========== TRIVY SCAN : PRODUCT =========="

                trivy image --severity HIGH,CRITICAL --exit-code 0 \
                ${DOCKERHUB_USER}/${IMAGE2}:${BUILD_NUMBER}

                echo "========== TRIVY SCAN : USERSERVICE =========="

                trivy image --severity HIGH,CRITICAL --exit-code 0 \
                ${DOCKERHUB_USER}/${IMAGE3}:${BUILD_NUMBER}
                """
            }
        }

        /* =========================================================
           PUSH IMAGES TO DOCKERHUB
        ========================================================= */
        stage('Push Images') {

            agent { label 'workernode3' }

            steps {

                withCredentials([
                    usernamePassword(
                        credentialsId: 'dockerhub-creds',
                        usernameVariable: 'USER',
                        passwordVariable: 'PASS'
                    )
                ]) {

                    sh """
                    echo "========== DOCKER LOGIN =========="

                    echo \$PASS | docker login -u \$USER --password-stdin

                    echo "========== PUSHING VERSION TAGS =========="

                    docker push ${DOCKERHUB_USER}/${IMAGE1}:${BUILD_NUMBER}

                    docker push ${DOCKERHUB_USER}/${IMAGE2}:${BUILD_NUMBER}

                    docker push ${DOCKERHUB_USER}/${IMAGE3}:${BUILD_NUMBER}

                    echo "========== PUSHING LATEST TAGS =========="

                    docker push ${DOCKERHUB_USER}/${IMAGE1}:latest

                    docker push ${DOCKERHUB_USER}/${IMAGE2}:latest

                    docker push ${DOCKERHUB_USER}/${IMAGE3}:latest
                    """
                }
            }
        }
    }

    /* =========================================================
       POST ACTIONS
    ========================================================= */
    post {

        success {

            echo "✅ DevSecOps Pipeline SUCCESS"
        }

        failure {

            echo "❌ DevSecOps Pipeline FAILED"
        }

        always {

            cleanWs()
        }
    }
}
