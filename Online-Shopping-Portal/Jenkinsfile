pipeline {
    agent none

    environment {
        DOCKERHUB_USER = "lakshvar96"
        IMAGE1 = "adminserver"
        IMAGE2 = "product"
        IMAGE3 = "userservice"
        GIT_REPO = "https://github.com/Lakshmanan1996/microservices-projects-store.git"
    }

    options {
        timestamps()
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    stages {

        /* ================= CHECKOUT ================= */
        stage('Checkout') {
            agent { label 'workernode1' }
            steps {
                git branch: 'master', url: "${GIT_REPO}"
            }
        }

        /* ================= DEBUG ================= */
        stage('Workspace Debug') {
            agent { label 'workernode1' }
            steps {
                sh """
                echo "Workspace structure:"
                pwd
                ls -R
                """
            }
        }

        

        /* ================= BUILD (GRADLE) ================= */
        stage('Build Services') {
            agent { label 'workernode1' }

            steps {
                sh """
                echo "Building adminserver"
                cd Online-Shopping-Portal/adminserver && ./gradlew clean build -x test || true

                echo "Building product"
                cd ../product && ./gradlew clean build -x test || true

                echo "Building userservice"
                cd ../userservice && ./gradlew clean build -x test || true
                """
            }
        }

        /* ================= SONAR ================= */
        stage('SonarQube Analysis') {
            agent { label 'workernode2' }
            
            steps {
                withSonarQubeEnv('sonarqube') {
                    sh """
                    ./gradlew clean build
                      -Dsonar.projectKey=kafka \
                      -Dsonar.projectName=kafka
                    """
                }
            }
        }

        /* ================= QUALITY GATE ================= */
        stage('Quality Gate') {
            agent { label 'workernode2' }

            steps {
                timeout(time: 2, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        /* ================= OWASP (SCA) ================= */
        stage('OWASP Dependency Check') {
            agent { label 'workernode2' }

            steps {
                dependencyCheck additionalArguments: '''
                    --scan .
                    --format HTML
                    --format XML
                    --out reports
                ''',
                odcInstallation: 'OWASP-DC'

                dependencyCheckPublisher pattern: '**/dependency-check-report.xml'
            }
        }

        /* ================= DOCKER BUILD ================= */
        stage('Docker Build') {
            agent { label 'workernode3' }

            steps {
                sh """
                echo "Building Docker images"

                docker build -t ${DOCKERHUB_USER}/${IMAGE1}:${BUILD_NUMBER} Online-Shopping-Portal/adminserver
                docker build -t ${DOCKERHUB_USER}/${IMAGE2}:${BUILD_NUMBER} Online-Shopping-Portal/product
                docker build -t ${DOCKERHUB_USER}/${IMAGE3}:${BUILD_NUMBER} Online-Shopping-Portal/userservice

                docker tag ${DOCKERHUB_USER}/${IMAGE1}:${BUILD_NUMBER} ${DOCKERHUB_USER}/${IMAGE1}:latest
                docker tag ${DOCKERHUB_USER}/${IMAGE2}:${BUILD_NUMBER} ${DOCKERHUB_USER}/${IMAGE2}:latest
                docker tag ${DOCKERHUB_USER}/${IMAGE3}:${BUILD_NUMBER} ${DOCKERHUB_USER}/${IMAGE3}:latest
                """
            }
        }

        /* ================= TRIVY ================= */
        stage('Trivy Scan') {
            agent { label 'workernode3' }

            steps {
                sh """
                echo "Scanning adminserver image"
                trivy image --severity HIGH,CRITICAL --exit-code 0 \
                ${DOCKERHUB_USER}/${IMAGE1}:${BUILD_NUMBER}

                echo "Scanning product image"
                trivy image --severity HIGH,CRITICAL --exit-code 0 \
                ${DOCKERHUB_USER}/${IMAGE2}:${BUILD_NUMBER}

                echo "Scanning userservice image"
                trivy image --severity HIGH,CRITICAL --exit-code 0 \
                ${DOCKERHUB_USER}/${IMAGE3}:${BUILD_NUMBER}
                """
            }
        }

        /* ================= DOCKER PUSH ================= */
        stage('Push Images') {
            agent { label 'workernode3' }

            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub-creds',
                    usernameVariable: 'USER',
                    passwordVariable: 'PASS'
                )]) {

                    sh """
                    echo $PASS | docker login -u $USER --password-stdin

                    docker push ${DOCKERHUB_USER}/${IMAGE1}:${BUILD_NUMBER}
                    docker push ${DOCKERHUB_USER}/${IMAGE2}:${BUILD_NUMBER}
                    docker push ${DOCKERHUB_USER}/${IMAGE3}:${BUILD_NUMBER}

                    docker push ${DOCKERHUB_USER}/${IMAGE1}:latest
                    docker push ${DOCKERHUB_USER}/${IMAGE2}:latest
                    docker push ${DOCKERHUB_USER}/${IMAGE3}:latest
                    """
                }
            }
        }
    }

    post {
        success {
            echo "✅ DevSecOps Pipeline SUCCESS"
        }
        failure {
            echo "❌ Pipeline FAILED"
        }
    }
}
